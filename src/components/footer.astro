---
import LinksFooter from "../components/links/Links-footer.astro";
---

<footer
  class="p-0 m-0 h-fit items-center justify-center flex flex-col relative"
>
  <div class="flex items-center justify-center bg-blue-200 w-full py-2">
    <ul class="flex-row flex gap-4">
      <li>
        <a href="https://discord.gg/RVX6RRqkt5" target="_blank">
          <i class="fa-brands fa-discord fa-xl text-stone-900"></i>
        </a>
      </li>
      <li>
        <a href="https://github.com/Create-Mastery" target="_blank">
          <i class="fa-brands fa-github fa-xl text-stone-900"></i>
        </a>
      </li>
    </ul>
  </div>

  <div
    class="bg-blue-300 w-full flex justify-center items-center flex-col py-2 gap-1"
  >
    <div
      class="w-1/3 flex flex-col md:flex-row justify-between items-center content-between gap-4"
    >
      <div class="w-fit">
        <h2 class="text-stone-900 text-2xl font-bold">Other Guides</h2>
        <hr />
        <LinksFooter link="/" text="The Best Complementary Mods" />
        <br />
        <LinksFooter link="/" text="Add-ons" />
      </div>
      <div class="w-fit">
        <h2 class="text-stone-900 text-2xl font-bold">Other Guides</h2>
        <hr />
        <LinksFooter
          link="mailto: info@createmastery.org"
          text="Info: info@createmastery.org"
        />
        <br />
        <LinksFooter link="/" text="About Us" />
      </div>
    </div>

    <div class="bg-blue-300 w-full text-center">
      <p class="text-stone-900 text-lg">
        Made with &#10084; by Create Mastery - Source code:
        <a
          href="https://github.com/Create-Mastery/website-new"
          target="_blank"
          class="text-stone-900 hover:underline">Github</a
        >
        - Version 1.0.8
      </p>
    </div>
  </div>
</footer>
