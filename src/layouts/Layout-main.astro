---
import "../styles/global.css";
import Links from "../components/links/Links.astro";
import Footer from "../components/footer.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="kinetic energy, Create, guide, Create Mastery"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script
      src="https://kit.fontawesome.com/f0be53b175.js"
      crossorigin="anonymous"></script>
    <title>{title}</title>
  </head>

  <body class="bg-stone-900 flex flex-col min-h-screen">
    <!----------- HEADER ----------->
    <header
      class="p-0 m-0 h-fit items-center justify-center flex flex-col relative"
    >
      <div
        class="bg-blue-300 flex flex-row w-full px-14 py-4 gap-5 justify-center items-center"
      >
        <a
          href="https://www.curseforge.com/minecraft/mc-mods/create"
          target="_blank"
          class="hidden md:block"
        >
          <img
            src="/favicon.svg"
            alt="Logo Create Mastery"
            class="size-32 select-none object-contain"
          />
        </a>
        <h1
          class="text-6xl font-bold text-stone-900 select-none text-center md:text-left"
        >
          CREATE MASTERY
        </h1>
      </div>
    </header>

    <!----------- NAVBAR ----------->
    <nav
      class="justify-end items-end sm:justify-center flex bg-blue-200 w-full h-fit sm:pt-1 flex-col sm:flex-row sticky top-0 z-1000"
    >
      <div
        id="menu-toggle"
        class="sm:hidden pr-5 py-3 w-full sm:w-auto flex justify-end"
      >
        <i
          class="fa-solid fa-bars text-stone-900 text-4xl hover:cursor-pointer"
          role="button"
          tabindex="0"
          onclick="
            const navLinks = document.getElementById('navLinks');
            const menuToggle = document.getElementById('menu-toggle');
            navLinks?.classList.toggle('hidden');
            menuToggle?.classList.toggle('bg-blue-300');
          "
        >
        </i>
      </div>

      <ul
        class="sm:flex sm:flex-row flex-col hidden w-full sm:w-auto sm:pb-3 p-2 justify-center"
        id="navLinks"
      >
        <li class="hover:bg-blue-300">
          <Links link="/guide" text="GUIDE" />
        </li>
        <li class="hover:bg-blue-300">
          <Links link="/" text="SCSDC" />
        </li>
        <li class="hover:bg-blue-300">
          <Links
            link="https://www.curseforge.com/minecraft/mc-mods/create"
            text="DOWNLOAD"
          />
        </li>
      </ul>
    </nav>

    <!----------- MAIN ----------->
    <main class="flex flex-col grow justify-center items-center mx-5">
      <slot />
    </main>

    <!----------- FOOTER ----------->
    <Footer />
  </body>
</html>
