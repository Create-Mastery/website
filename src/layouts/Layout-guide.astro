---
import "../styles/global.css";
import Footer from "../components/footer.astro";
import SideBarEntryNode from "../components/guide/Side-bar-entry-node.astro";
import SideBarEntryNodeInternal from "../components/guide/Side-bar-entry-node-internal.astro";
import SideBarEntry from "../components/guide/Side-bar-entry.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="kinetic energy, Create, guide" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script
      src="https://kit.fontawesome.com/f0be53b175.js"
      crossorigin="anonymous"></script>
    <title>{title}</title>
  </head>
  <body class="bg-stone-900 flex flex-col min-h-screen">
    <header
      class="p-0 m-0 h-fit items-center justify-center flex flex-col relative"
    >
      <div
        class="bg-blue-300 flex sm:flex-row w-full px-7 py-4 gap-5 lg:justify-start justify-center items-center"
      >
        <img
          src="/favicon.svg"
          alt="Logo Create Mastery"
          class="size-16 select-none object-contain"
        />

        <span
          class="text-4xl font-bold text-stone-900 select-none whitespace-nowrap"
        >
          CREATE MASTERY
        </span>
      </div>
      <div
        class="px-4 w-full lg:justify-center justify-between h-fit items-center flex flex-row select-none bg-blue-200"
      >
        <div class="flex">
          <a
            href="/"
            class="text-stone-900 text-2xl font-bold lg:hover:bg-blue-300 p-2"
            target="_blank"
          >
            HOME
          </a>
          <a
            href="/"
            target="_blank"
            class="text-stone-900 text-2xl font-bold lg:hover:bg-blue-300 p-2"
          >
            SCSDC
          </a>
          <a
            href="https://github.com/Create-Mastery"
            target="_blank"
            class="text-stone-900 text-2xl font-bold lg:hover:bg-blue-300 p-2"
          >
            GITHUB
          </a>
        </div>
        <div>
          <div
            id="menu-toggle"
            class="lg:hidden p-2 px-4 w-full sm:w-auto flex justify-end"
          >
            <i
              class="fa-solid fa-bars text-stone-900 text-4xl hover:cursor-pointer"
              role="button"
              tabindex="0"
              onclick="
                const navLinks = document.getElementById('sideBar');
                navLinks?.classList.toggle('hidden');
              "
            >
            </i>
          </div>
        </div>
      </div>
    </header>
    <main class="flex flex-grow">
      <!----------- MAIN ----------->
      <div
        class="lg:w-md lg:min-w-2xs min-w-full bg-stone-800 hidden lg:flex"
        id="sideBar"
      >
        <div class="flex flex-col gap-2 p-3 w-full">
          <SideBarEntry>
            <a href="/guide">INTRODUCTION</a>
          </SideBarEntry>
          <SideBarEntryNode title="1. KINETIC ENERGY" id="1">
            <SideBarEntry>
              <a href="/guide/kinetic-energy-intro">
                1.1 WHAT IS KINETIC ENERGY?
              </a>
            </SideBarEntry>
            <SideBarEntryNodeInternal
              title="1.2 KINETIC ENERGY GENERATORS"
              id="2"
            >
              <SideBarEntry>
                <a href="/guide/steam-engine"> 1.2.1 STEAM ENGINE </a>
              </SideBarEntry>

              <SideBarEntry>
                <a href="/guide/windmill"> 1.2.2 WINDMILL </a>
              </SideBarEntry>

              <SideBarEntry>
                <a href="/guide/water-wheels"> 1.2.3 WATER WHEELS </a>
              </SideBarEntry>

              <SideBarEntry>
                <a href="/guide/hand-crank"> 1.2.4 HAND CRANK </a>
              </SideBarEntry>

              <SideBarEntry>
                <a href="/guide/conclusion"> 1.2.5 CONCLUSIONS </a>
              </SideBarEntry>
            </SideBarEntryNodeInternal>
          </SideBarEntryNode>
        </div>
      </div>
      <div>
        <div class="mx-5 my-2.5 xl:w-5xl">
          <slot />
        </div>
      </div>
    </main>

    <!----------- FOOTER ----------->
    <Footer />

    <script type="module" src="/scripts/sidebar/init.js"></script>
  </body>
</html>
